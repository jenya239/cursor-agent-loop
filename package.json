{
  "name": "cr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:ui": "esbuild src/ui/app.ts --bundle --outfile=public/bundle.js --format=iife --platform=browser",
    "predev": "npm run build:ui",
    "dev:ui": "esbuild src/ui/app.ts --bundle --outfile=public/bundle.js --format=iife --platform=browser --watch",
    "start": "node dist/server.js",
    "dev": "concurrently -k \"tsx src/server.ts\" \"npm run dev:ui\"",
    "dev:server": "tsx src/server.ts",
    "probe:dump": "tsx scripts/probe-dump.ts",
    "probe:bar": "tsx scripts/probe-bar.ts",
    "probe:panel": "tsx scripts/probe-panel.ts",
    "probe:interaction": "tsx scripts/probe-interaction.ts",
    "probe:layout": "tsx scripts/probe-layout.ts",
    "probe:layout-discover": "tsx scripts/probe-layout-discover.ts",
    "test": "jest",
    "test:e2e": "playwright test",
    "fixture:record": "tsx scripts/fixture-record.ts",
    "mcp": "node dist/mcp/stdio-main.js",
    "queue:debug": "tsx scripts/queue-debug.ts",
    "queue:flush": "tsx scripts/queue-debug.ts flush",
    "watchdog:start": "tsx scripts/watchdog.ts start",
    "watchdog:stop": "tsx scripts/watchdog.ts stop",
    "watchdog:status": "tsx scripts/watchdog.ts status",
    "overnight:guard": "tsx scripts/overnight-guard.ts",
    "overnight:guard:mlc": "CR_GUARD_TARGET=mlc tsx scripts/overnight-guard.ts",
    "overnight:guard:cr": "CR_GUARD_TARGET=cr tsx scripts/overnight-guard.ts",
    "overnight:loop": "bash scripts/overnight-loop.sh",
    "pick:agent-next": "tsx scripts/pick-agent-next.ts",
    "pick:agent-next:mlc": "tsx scripts/pick-agent-next.ts mlc",
    "pick:agent-next:cr": "tsx scripts/pick-agent-next.ts cr",
    "probe:usage": "tsx scripts/probe-usage.ts",
    "supervisor": "tsx scripts/supervisor.ts",
    "premcp": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.9.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
